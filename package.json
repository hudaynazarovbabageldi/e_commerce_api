        "express-async-handler": "^1.2.0",
        "express-rate-limit": "^8.2.1",
        "express-slow-down": "^3.0.1",
        "helmet": "^8.1.0",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.3",
